      // ============================================================
      // RENDER ENGINE
      // ============================================================
      function renderSidebar() {
        const sb = document.getElementById('sidebar');
        let html = `<div class="sidebar-header">
    <h1>Fullstack Guide</h1>
    <p>HTML → CSS → JS → Node → Vue</p>
  </div><nav class="sidebar-nav">`;

        subjects.forEach((subj, si) => {
          html += `<div class="nav-group${si === 0 ? ' open' : ''}" data-subject="${subj.id}">
      <div class="nav-group-title" onclick="toggleGroup(this)">
        <span class="dot" style="background:${subj.color}"></span>
        ${subj.label}
        <span class="arrow">▶</span>
      </div>
      <div class="nav-items">`;
          subj.sections.forEach((sec) => {
            html += `<div class="nav-item" data-section="${sec.id}" onclick="navigateTo('${subj.id}','${sec.id}')">${sec.title.replace(/⭐/g, '').trim()}</div>`;
          });
          html += `</div></div>`;
        });
        html += `</nav>`;
        sb.innerHTML = html;
      }

      function renderPage(subjectId) {
        const subj = subjects.find((s) => s.id === subjectId);
        if (!subj) return;

        let html = `<div class="${subj.className}">
    <div class="page-header">
      <span class="badge" style="background:${subj.color}22;color:${subj.color}">${subj.badge}</span>
      <h2>${subj.title}</h2>
      <p>${subj.desc}</p>
    </div>`;

        subj.sections.forEach((sec) => {
          html += `<div class="section" id="${sec.id}">
      <h3><span class="icon">§</span> ${sec.title}</h3>
      ${sec.content}
    </div>`;
        });

        html += `</div>`;
        document.getElementById('content').innerHTML = html;
        document
          .querySelectorAll('pre code')
          .forEach((el) => hljs.highlightElement(el));
      }

      function navigateTo(subjectId, sectionId) {
        // Update active states
        document.querySelectorAll('.nav-group').forEach((g) => {
          if (g.dataset.subject === subjectId) g.classList.add('open');
        });
        document
          .querySelectorAll('.nav-item')
          .forEach((i) => i.classList.remove('active'));
        const activeItem = document.querySelector(
          `.nav-item[data-section="${sectionId}"]`,
        );
        if (activeItem) activeItem.classList.add('active');

        // Render and scroll
        renderPage(subjectId);
        setTimeout(() => {
          const target = document.getElementById(sectionId);
          if (target)
            target.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }, 50);

        // Close mobile sidebar
        document.querySelector('.sidebar').classList.remove('open');
      }

      function toggleGroup(el) {
        const group = el.parentElement;
        group.classList.toggle('open');
        if (group.classList.contains('open')) {
          const subjectId = group.dataset.subject;
          const subj = subjects.find((s) => s.id === subjectId);
          if (subj && subj.sections.length > 0) {
            navigateTo(subjectId, subj.sections[0].id);
          }
        }
      }

      // Init
      renderSidebar();
      navigateTo('html', 'html-structure');
    </script>
